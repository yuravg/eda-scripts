#!/usr/bin/env bash

# Jtagconfig output example:
# 1) USB-Blaster [USB-0]
#   02B020DD   5CGTFD5(C5|F5)/5CGXBC5C(6|7)/..
#
# 2) USB-Blaster [USB-1]
#   Unable to read device chain - JTAG chain broken


# substr="foo"
# nonsub="$(echo "$string" | sed "s/$substr//")"
# hassub=0 ; [ "$string" != "$nonsub" ] && hassub=1

jtag_rpt=$(jtagconfig)
jtag_name="$(echo "$jtag_rpt" | sed 's/[0-9])\s-*\(.*\)\s-*\(.*\)/\1\2/g')"

name_array=( $jtag_name )

for (( i=0; i<=${#name_array[@]}; i++ )); do
    str="${name_array[$i]}"
    clear_name="$(echo "$str" | sed 's/U.*]//')"
    if [[ "$str" != "$clear_name" ]]; then
        echo "$str"
    fi
done


