#!/usr/bin/env bash

# Convert sof-file to jic-file from Quartus Prime project directory

SCRIPT_NAME="${BASH_SOURCE##*/}"

DEVICE=""
CFG_DEVICE=""
CFG_SCH=""

qp_prj_info() {
    PRJ=$(ls ./*.qpf 2>/dev/null)

    if [ -z "$PRJ" ]; then
        echo "ERROR! Can not find Quartus Prime project (qsf) file!"
        exit 0
    else
        echo "Project file: $PRJ"
    fi
}

parsing_revision_file() {
    REVFNAME="$1"

    DEVICE=$("$CMD" "$CMD_FLAGS" -e "-name DEVICE\s" "$REVFNAME" | \
                 sed 's/.*DEVICE\s*\(.*\)/\1/')

    CFG_DEVICE=$("$CMD" "$CMD_FLAGS" -e "-name\s.*CONFIGURATION_DEVICE\s" "$REVFNAME" | \
                     "$CMD" "$CMD_FLAGS" -e "\s*EPC" | \
                     sed 's/.*CONFIGURATION_DEVICE\s*\(.*\)/\1/')

    CFG_STR=$("$CMD" "$CMD_FLAGS" -e "-name\s.*CONFIGURATION_SCHEME\s" "$REVFNAME" | \
                     sed 's/.*CONFIGURATION_SCHEME\s*\"\(.*\)\"/\1/')
    if [ "$CFG_STR" == "ACTIVE SERIAL X1" ]; then
        CFG_SCH=ASx1
    elif [ "$CFG_STR" == "ACTIVE SERIAL X4" ]; then
        CFG_SCH=ASx4
    else
        echo "'$SCRIPT_NAME' ERROR! Unsupported configuration scheme!"
        exit 1
    fi
}

qp_revision_info() {
    cnt=1
    for p in $(ls $OUTDIR*.qsf 2>/dev/null); do
        revision[$cnt]=$p
        cnt=`expr $cnt + 1`
    done

    echo "Revision(s):"
    for (( i=1; i<${#revision[@]}+1; i++ )); do
        REVFNAME=${revision[${i}]}
        echo "$i. $REVFNAME"
        parsing_revision_file "$REVFNAME"
    done
}

if hash rg 2>/dev/null; then
    CMD=rg
    CMD_FLAGS="-IN"
else
    CMD=grep
    CMD_FLAGS="-h"
fi

qp_prj_info
qp_revision_info


quartus_cpf.exe -c -o BITSTREAM_COMPRESSION=ON -d "$DEVICE" -m "$CFG_SCH" -s "$DEVICE" fname.sof fname.jic


echo "$DEVICE"
echo "$CFG_DEVICE"
echo "$CFG_SCH"
